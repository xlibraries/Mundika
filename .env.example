# Copy to `.env.local` for Next.js (never commit real secrets).
# Razorpay Key secret belongs only in Supabase Edge secrets + Razorpay Dashboard.

# Public key for Standard Checkout (same Key ID as dashboard test/live).
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Optional: same values for local tooling only — prefer Supabase secrets for Edge.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
