# Supabase → Authentication → URL Configuration
# - Site URL must be the app base (e.g. http://localhost:3000 or https://user.github.io/Repo).
#   Do not set Site URL to .../auth/callback — that belongs under Redirect URLs only.
# - Redirect URLs: add http://localhost:3000/auth/callback and your Pages .../auth/callback.

# App origin (no path). OAuth redirect URL is built as origin + NEXT_PUBLIC_BASE_PATH.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# GitHub Pages project site only — same value as CI (repo name, e.g. /Mundika). Leave empty locally.
# NEXT_PUBLIC_BASE_PATH=/Mundika
