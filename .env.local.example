# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://jtqvahhamlvywzgpokbv.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_spJ-Q7zaDSKS8ucFtufvrA_1thOowd4

# Supabase → Authentication → URL Configuration
# - Site URL must be the app base (e.g. http://localhost:3000 or https://user.github.io/Repo).
#   Do not set Site URL to .../auth/callback — that belongs under Redirect URLs only.
# - Redirect URLs: add http://localhost:3000/auth/callback and your Pages .../auth/callback.
#
# Email OTP signup (Create account): Supabase Dashboard → Authentication → Email templates
# → "Magic link" (OTP request): include {{ .Token }} in the body so users receive a numeric
# code instead of only {{ .ConfirmationURL }}. See Supabase Auth docs for signInWithOtp / verifyOtp.

# App origin (no path). OAuth redirect URL is built as origin + NEXT_PUBLIC_BASE_PATH.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Next.js dev only: hosts allowed for HMR / `/_next/*` when you open the app by LAN IP (no scheme).
# Example if your machine is http://192.168.1.52:3000 → set:
# NEXT_DEV_ALLOWED_ORIGINS=192.168.1.52
# If HMR still fails, try: pnpm run dev:webpack
# GitHub Pages project site only — same value as CI (repo name, e.g. /Mundika). Leave empty locally.
# NEXT_PUBLIC_BASE_PATH=/Mundika

# Payment provider for SaaS Starter checkout: stripe | razorpay (Razorpay APIs are not in the app yet).
# NEXT_PUBLIC_PAYMENT_PROVIDER=stripe

# Stripe SaaS (Starter subscription) — secrets live on Supabase Edge Functions, not in the static bundle.
# Client: show “Subscribe to Starter” on /account when this is true (after functions are deployed).
# NEXT_PUBLIC_STRIPE_CHECKOUT_ENABLED=true
#
# Set these in the Supabase project (Dashboard → Edge Functions → Secrets, or `supabase secrets set`):
#   STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_PRICE_ID_STARTER,
#   SUPABASE_SERVICE_ROLE_KEY, SITE_URL (exact site root, include NEXT_PUBLIC_BASE_PATH if used, e.g. https://user.github.io/Mundika)
#
# Stripe Dashboard → Developers → Webhooks → endpoint:
#   https://<project-ref>.supabase.co/functions/v1/stripe-webhook

# Razorpay Starter (Edge: create-razorpay-order, verify-razorpay-payment,
# razorpay-confirm-payment, razorpay-webhook). Static export has no /api routes;
# the app calls these via supabase.functions.invoke(...).
# NEXT_PUBLIC_PAYMENT_PROVIDER=razorpay
# NEXT_PUBLIC_RAZORPAY_CHECKOUT_ENABLED=true
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...   # Key ID only — never put KEY_SECRET here
#
# Supabase Edge secrets (Dashboard or `supabase secrets set`): RAZORPAY_KEY_ID,
# RAZORPAY_KEY_SECRET, RAZORPAY_WEBHOOK_SECRET, optional RAZORPAY_STARTER_AMOUNT_PAISE=39900
