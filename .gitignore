# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secrets) — keep committed examples like .env.local.example
.env
.env.*
!.env.example
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# Next.js (regenerated by dev/build)
next-env.d.ts

# RuFlo: regenerated on init/upgrade; reinstall docs via `npx ruflo@latest init check`
.claude-flow/CAPABILITIES.md

# eslint
.eslintcache

# turbo
.turbo

# IDEs (optional local junk; remove a line if your team commits these)
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Supabase CLI local state
supabase/.branches
supabase/.temp

# Ruflo / Claude Flow local runtime (see also .claude-flow/.gitignore)
.claude-flow/data/
.claude-flow/logs/
.claude-flow/sessions/
.claude-flow/neural/
*.log
*.tmp
